# Configuración del servicio Flask K-Means
PORT=8000
FLASK_ENV=production

# Base de Datos PostgreSQL (Railway)
# Copiar el DATABASE_URL de Railway
DATABASE_URL=postgresql://user:password@host:port/database

# API URLs (para CORS y comunicación)
LARAVEL_API_URL=https://api.trailynsafe.lat
FRONTEND_URL=https://trailynsafe.lat

# Configuración de análisis
DEFAULT_N_SAMPLES=1000
MAX_CLUSTERS=6

# Logging
LOG_LEVEL=INFO

# Nota: Asegúrate de crear un archivo .env con estos valores antes de desplegar
# El servicio usará los datos de viajes, confirmaciones y asistencias de la BD



